# Backend Server Environment Variables
# Copy this file to .env and update with production values

# Server
PORT=5000
NODE_ENV=production

# ⚠️ CRITICAL: Frontend URLs for CORS
# Format: https://domain1.com,https://domain2.com (comma-separated, NO SPACES)
# These MUST match the exact origin that browsers send (protocol + domain + port if non-standard)
# Examples:
#   Development: http://localhost:3000,http://localhost:3001
#   Production: https://admin.yourdomain.com,https://home.yourdomain.com
#   Staging: https://admin-staging.yourdomain.com,https://home-staging.yourdomain.com
FRONTEND_URL=https://admin.yourdomain.com,https://home.yourdomain.com

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carrent

# JWT Secret for Admin Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters long
ADMIN_JWT_SECRET=your_super_secure_jwt_secret_here_min_32_chars

# Optional: Cloudinary or other file upload service
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: Payment gateway (Cashfree)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
